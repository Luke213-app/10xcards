+// Migrated to a function component with hooks.
+function UserList({ endpoint, title }) {
+  const [users, setUsers] = useState([]);
+  const [loading, setLoading] = useState(true);
+
+  useEffect(() => {
+    setLoading(true);
+    fetch(endpoint)
+      .then((r) => r.json())
+      .then((data) => {
+        setUsers(data);
+        setLoading(false);
+      });
+  }, []);
+
+  if (loading) return <p>Loading…</p>;
+  return (
+    <section>
+      <h2>{title.toUpperCase()}</h2>
+      <ul>
+        {users.map((u) => (
+          <li key={u.id}>{u.name}</li>
+        ))}
+      </ul>
+    </section>
+  );
+}
+
+UserList.defaultProps = { endpoint: '/api/users', title: 'Users' };

 export default UserList;
