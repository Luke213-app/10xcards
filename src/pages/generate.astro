---
import Layout from "@/layouts/Layout.astro";
import CreateCard from "@/components/generate/CreateCard";
import AppHeader from "@/components/AppHeader.astro";
import AppFooter from "@/components/AppFooter.astro";

// Auth is enforced by middleware (PROTECTED_ROUTES). The CreateCard island owns
// all state; the toggle's initial mode comes from ?mode (default "ai"), so
// /cards/new -> /generate?mode=manual opens directly in the Manual flow.
const initialMode = Astro.url.searchParams.get("mode") === "manual" ? "manual" : "ai";
---

<Layout title="Create flashcards">
  <div class="bg-cosmic flex min-h-screen flex-col p-4 text-white sm:p-8">
    <AppHeader />
    <main class="mx-auto w-full max-w-3xl flex-1 py-6">
      <div class="mb-8">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Create flashcards
        </h1>
        <p class="mt-1 text-sm text-blue-100/60">Generate cards from your notes with AI, or write one by hand.</p>
      </div>
      <CreateCard client:load initialMode={initialMode} />
    </main>

    <AppFooter />
  </div>
</Layout>
