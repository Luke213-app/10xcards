---
import Layout from "@/layouts/Layout.astro";
import Panel from "@/components/ui/Panel.astro";
import Badge from "@/components/ui/Badge.astro";
import AccountMenu from "@/components/AccountMenu.astro";
import AppFooter from "@/components/AppFooter.astro";

// Dashboard hub (R2): hero + three action blocks. No nav — just the account
// avatar (top-right) for sign-out. Auth is enforced by middleware
// (PROTECTED_ROUTES).
---

<Layout title="Dashboard">
  <div class="flex min-h-screen flex-col p-4 sm:p-8">
    <header class="flex w-full justify-end">
      <AccountMenu />
    </header>
    <main class="mx-auto flex w-full max-w-2xl flex-1 flex-col justify-center py-16">
      <h1 class="text-foreground mb-12 text-center font-sans text-4xl font-extrabold tracking-[-0.02em] sm:text-5xl">
        What are you up to <span class="text-primary">today?</span>
      </h1>

      <div class="space-y-4">
        <a href="/review" class="block">
          <Panel class="zen-press flex items-center gap-4 p-5">
            <span
              class="border-foreground bg-accent text-accent-foreground flex size-11 items-center justify-center border-2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"
                ></path>
                <path d="M22 10v6"></path>
                <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"></path>
              </svg>
            </span>
            <span class="text-foreground text-base font-medium tracking-[0.08em] uppercase">I want to Learn</span>
          </Panel>
        </a>

        <a href="/cards" class="block">
          <Panel class="zen-press flex items-center gap-4 p-5">
            <span
              class="border-foreground bg-accent text-accent-foreground flex size-11 items-center justify-center border-2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="18" height="18" x="3" y="3" rx="2"></rect>
                <path d="M3 9h18"></path>
                <path d="M9 21V9"></path>
              </svg>
            </span>
            <span class="text-foreground text-base font-medium tracking-[0.08em] uppercase">Browse my cards</span>
          </Panel>
        </a>

        <Panel class="flex items-center gap-4 p-5 opacity-60">
          <span
            class="border-foreground bg-accent text-accent-foreground flex size-11 items-center justify-center border-2"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.84Z"
              ></path>
              <path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12"></path>
              <path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17"></path>
            </svg>
          </span>
          <span class="text-foreground text-base font-medium tracking-[0.08em] uppercase">Create a deck</span>
          <Badge class="ml-auto">Coming soon</Badge>
        </Panel>
      </div>
    </main>

    <AppFooter />
  </div>
</Layout>
