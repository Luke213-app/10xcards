---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { listDueFlashcards } from "@/lib/services/flashcards";
import ReviewSession from "@/components/review/ReviewSession";
import AppHeader from "@/components/AppHeader.astro";
import AppFooter from "@/components/AppFooter.astro";

// Auth is enforced by middleware (PROTECTED_ROUTES). The due queue is fetched
// server-side via the RLS-scoped client (a user only ever sees their own cards),
// with each card's four interval previews precomputed, and handed to the
// ReviewSession island, which owns the flip-then-grade loop.
const supabase = createClient(Astro.request.headers, Astro.cookies);
// Distinguish "secrets unset / cannot load" from "genuinely nothing due".
const configured = supabase !== null;
const dueCards = supabase ? await listDueFlashcards(supabase) : [];
---

<Layout title="Review">
  <div class="bg-cosmic flex min-h-screen flex-col p-4 text-white sm:p-8">
    <AppHeader />
    <main class="mx-auto w-full max-w-3xl flex-1 py-6">
      <div class="mb-8">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Review
        </h1>
        <p class="mt-1 text-sm text-blue-100/60">
          {
            configured && dueCards.length > 0
              ? `${dueCards.length} card${dueCards.length === 1 ? "" : "s"} due.`
              : "Your spaced-repetition session."
          }
        </p>
      </div>

      {
        !configured ? (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <p class="text-sm text-red-300">Review is unavailable right now. Please try again later.</p>
          </section>
        ) : dueCards.length === 0 ? (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center">
            <h2 class="text-lg font-semibold text-white">You&apos;re all caught up</h2>
            <p class="mx-auto mt-1 max-w-md text-sm text-blue-100/60">
              No cards are due right now. Generate or add more cards, or come back later.
            </p>
            <div class="mt-6 flex items-center justify-center gap-3">
              <a
                href="/cards"
                class="inline-block rounded-lg bg-purple-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-purple-500"
              >
                My cards
              </a>
              <a
                href="/generate"
                class="inline-block rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-white/20"
              >
                Create flashcards
              </a>
            </div>
          </section>
        ) : (
          <ReviewSession cards={dueCards} client:load />
        )
      }
    </main>

    <AppFooter />
  </div>
</Layout>
