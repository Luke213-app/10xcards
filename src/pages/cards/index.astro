---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { listFlashcards } from "@/lib/services/flashcards";
import CardList from "@/components/cards/CardList";
import AppHeader from "@/components/AppHeader.astro";
import AppFooter from "@/components/AppFooter.astro";

// Auth is enforced by middleware (PROTECTED_ROUTES). The list is fetched
// server-side via the RLS-scoped client (a user only ever sees their own cards)
// and handed to the CardList island, which owns edit/delete interactivity.
const supabase = createClient(Astro.request.headers, Astro.cookies);
// Distinguish "secrets unset / cannot load" from "genuinely empty collection".
const configured = supabase !== null;
const cards = supabase ? await listFlashcards(supabase) : [];
---

<Layout title="My cards">
  <main class="bg-cosmic min-h-screen p-4 text-white sm:p-8">
    <AppHeader />
    <div class="mx-auto w-full max-w-3xl py-6">
      <div class="mb-8">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          My cards
        </h1>
        <p class="mt-1 text-sm text-blue-100/60">Your saved flashcard collection.</p>
      </div>

      {
        !configured ? (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <p class="text-sm text-red-300">Your collection is unavailable right now. Please try again later.</p>
          </section>
        ) : cards.length === 0 ? (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center">
            <h2 class="text-lg font-semibold text-white">No cards yet</h2>
            <p class="mx-auto mt-1 max-w-md text-sm text-blue-100/60">
              Generate flashcards from your notes, or add one by hand to start your collection.
            </p>
            <div class="mt-6 flex items-center justify-center gap-3">
              <a
                href="/generate"
                class="inline-block rounded-lg bg-purple-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-purple-500"
              >
                Generate flashcards
              </a>
              <a
                href="/generate?mode=manual"
                class="inline-block rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-white/20"
              >
                Add card manually
              </a>
            </div>
          </section>
        ) : (
          <CardList cards={cards} client:load />
        )
      }
    </div>

    <AppFooter />
  </main>

  <!-- Floating "Add card" entry → consolidated creation surface -->
  <a
    href="/generate"
    aria-label="Add card"
    class="fixed right-6 bottom-6 z-20 inline-flex items-center gap-2 rounded-full bg-purple-600 px-5 py-3 text-sm font-medium text-white shadow-lg shadow-purple-900/40 transition-colors hover:bg-purple-500"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M5 12h14"></path>
      <path d="M12 5v14"></path>
    </svg>
    Add card
  </a>
</Layout>
