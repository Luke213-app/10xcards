---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { listFlashcards } from "@/lib/services/flashcards";
import CardList from "@/components/cards/CardList";
import AppHeader from "@/components/AppHeader.astro";
import AppFooter from "@/components/AppFooter.astro";
import AddCardModal from "@/components/cards/AddCardModal";

// Auth is enforced by middleware (PROTECTED_ROUTES). The list is fetched
// server-side via the RLS-scoped client (a user only ever sees their own cards)
// and handed to the CardList island, which owns edit/delete interactivity.
const supabase = createClient(Astro.request.headers, Astro.cookies);
// Distinguish "secrets unset / cannot load" from "genuinely empty collection".
const configured = supabase !== null;
const cards = supabase ? await listFlashcards(supabase) : [];
---

<Layout title="My cards">
  <div class="bg-cosmic flex min-h-screen flex-col p-4 text-white sm:p-8">
    <AppHeader />
    <main class="mx-auto w-full max-w-3xl flex-1 py-6">
      <div class="mb-8">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          My cards
        </h1>
        <p class="mt-1 text-sm text-blue-100/60">Your saved flashcard collection.</p>
      </div>

      {
        !configured ? (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <p class="text-sm text-red-300">Your collection is unavailable right now. Please try again later.</p>
          </section>
        ) : cards.length === 0 ? (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center">
            <h2 class="text-lg font-semibold text-white">No cards yet</h2>
            <p class="mx-auto mt-1 max-w-md text-sm text-blue-100/60">
              Tap the “Add card” button to generate flashcards from your notes or write one by hand.
            </p>
          </section>
        ) : (
          <CardList cards={cards} client:load />
        )
      }
    </main>

    <AppFooter />
  </div>

  <!-- Floating "Add card" entry → opens the creation modal (AI / Manual) -->
  <AddCardModal client:load />
</Layout>
