---
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { listFlashcards } from "@/lib/services/flashcards";
import type { FlashcardSource } from "@/types";

// Auth is enforced by middleware (PROTECTED_ROUTES). Read-only browse view:
// the list is fetched server-side via the RLS-scoped client, so a user only
// ever sees their own cards. No island, no client JS.
const { user } = Astro.locals;

const supabase = createClient(Astro.request.headers, Astro.cookies);
// Distinguish "secrets unset / cannot load" from "genuinely empty collection".
const configured = supabase !== null;
const cards = supabase ? await listFlashcards(supabase) : [];

// Human-readable label per origin (mirrors the FlashcardSource enum exactly).
const SOURCE_LABELS: Record<FlashcardSource, string> = {
  "ai-full": "AI",
  "ai-edited": "AI (edited)",
  manual: "Manual",
};

const dateFmt = new Intl.DateTimeFormat("en-US", { dateStyle: "medium" });
const formatDate = (iso: string) => dateFmt.format(new Date(iso));
---

<Layout title="My cards">
  <main class="bg-cosmic min-h-screen p-4 text-white">
    <div class="mx-auto w-full max-w-3xl py-10">
      <header class="mb-8 flex items-center justify-between">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
            My cards
          </h1>
          <p class="mt-1 text-sm text-blue-100/60">
            Your saved flashcard collection{user?.email ? `, ${user.email}` : ""}.
          </p>
        </div>
        <div class="flex items-center gap-4">
          <a href="/cards/new" class="text-sm text-purple-300 hover:underline">Add manually</a>
          <a href="/generate" class="text-sm text-purple-300 hover:underline">Generate</a>
          <a href="/dashboard" class="text-sm text-purple-300 hover:underline">Dashboard</a>
        </div>
      </header>

      {
        !configured ? (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-6">
            <p class="text-sm text-red-300">Your collection is unavailable right now. Please try again later.</p>
          </section>
        ) : cards.length === 0 ? (
          <section class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center">
            <h2 class="text-lg font-semibold text-white">No cards yet</h2>
            <p class="mx-auto mt-1 max-w-md text-sm text-blue-100/60">
              Generate flashcards from your notes, or add one by hand to start your collection.
            </p>
            <div class="mt-6 flex items-center justify-center gap-3">
              <a
                href="/generate"
                class="inline-block rounded-lg bg-purple-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-purple-500"
              >
                Generate flashcards
              </a>
              <a
                href="/cards/new"
                class="inline-block rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-white/20"
              >
                Add card manually
              </a>
            </div>
          </section>
        ) : (
          <ul class="space-y-4">
            {cards.map((card) => (
              <li class="rounded-2xl border border-white/10 bg-white/5 p-6">
                <div class="mb-2 flex items-center justify-between gap-3">
                  <span class="rounded-full border border-white/15 bg-white/10 px-2.5 py-0.5 text-xs font-medium text-blue-100/80">
                    {SOURCE_LABELS[card.source]}
                  </span>
                  <time datetime={card.createdAt} class="text-xs text-blue-100/50">
                    {formatDate(card.createdAt)}
                  </time>
                </div>
                <p class="font-semibold whitespace-pre-wrap text-white">{card.front}</p>
                <p class="mt-2 text-sm whitespace-pre-wrap text-blue-100/70">{card.back}</p>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </main>
</Layout>
