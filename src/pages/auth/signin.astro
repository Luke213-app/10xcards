---
import Layout from "@/layouts/Layout.astro";
import Card from "@/components/ui/Card.astro";
import SignInForm from "@/components/auth/SignInForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Sign in">
  <div class="flex min-h-screen items-center justify-center p-4">
    <Card class="w-full max-w-sm p-8">
      <h1 class="text-foreground mb-6 text-center font-sans text-2xl font-extrabold tracking-[-0.02em]">Sign in</h1>
      <SignInForm serverError={error} client:load />
      <p class="text-muted-foreground mt-4 text-center text-sm">
        Don't have an account? <a href="/auth/signup" class="text-primary hover:underline">Sign up</a>
      </p>
    </Card>
  </div>
</Layout>
