---
import Badge from "@/components/ui/Badge.astro";
import Panel from "@/components/ui/Panel.astro";
import Cta from "@/components/ui/Cta.astro";
import AppFooter from "@/components/AppFooter.astro";

// Public landing (R1). Matches reference/ref-landing.png. A logged-in visitor
// never reaches this — middleware redirects them to /dashboard (Phase 2).
const features = [
  {
    title: "Active recall",
    body: "Test yourself instead of re-reading. Retrieval builds stronger memory traces.",
    icon: "recall",
  },
  {
    title: "Spaced repetition",
    body: "Review each card right before you'd forget it. Less time, deeper retention.",
    icon: "repeat",
  },
  {
    title: "It's for free",
    body: "Free forever. We will never charge you for anything!",
    icon: "zap",
  },
];
---

<div class="bg-background relative min-h-screen w-full overflow-hidden">
  <div class="relative z-10 p-4 sm:p-8">
    <!-- Public header (not AppHeader): brand + Sign in / Sign up -->
    <header class="mx-auto flex w-full max-w-5xl items-center justify-between gap-4">
      <a href="/" class="text-foreground flex items-center gap-2 transition-opacity hover:opacity-80">
        <span class="zen-shadow bg-primary text-primary-foreground flex size-8 items-center justify-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 2a3 3 0 0 0-3 3v14a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path>
            <path d="M9 8h6"></path>
          </svg>
        </span>
        <span class="font-sans text-base font-extrabold tracking-[-0.02em]">Recall</span>
      </a>
      <div class="flex items-center gap-3 text-[11px] tracking-[0.1em] uppercase">
        <a href="/auth/signin" class="text-muted-foreground hover:text-foreground transition-colors">Sign in</a>
        <Cta href="/auth/signup" variant="secondary">Sign up</Cta>
      </div>
    </header>

    <!-- Hero section -->
    <div class="mx-auto flex max-w-4xl flex-col items-center justify-center px-4 py-24 text-center sm:py-32">
      <Badge variant="tint" class="mb-8">Free &amp; open source</Badge>
      <h1
        class="text-foreground mb-6 font-sans text-5xl leading-tight font-extrabold tracking-[-0.03em] sm:text-6xl lg:text-7xl"
      >
        Remember <span class="text-primary">everything</span> you learn.
      </h1>
      <p class="text-muted-foreground max-w-2xl text-lg sm:text-xl">
        Flashcard program that helps you memorize vast amounts of information.
      </p>
    </div>

    <!-- Feature cards -->
    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-6 px-4 pb-24 sm:grid-cols-3">
      {
        features.map((feature) => (
          <Panel class="p-6">
            <span class="border-foreground bg-accent text-accent-foreground mb-4 flex size-10 items-center justify-center border-2">
              {feature.icon === "recall" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10" />
                  <circle cx="12" cy="12" r="6" />
                  <circle cx="12" cy="12" r="2" />
                </svg>
              )}
              {feature.icon === "repeat" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m17 2 4 4-4 4" />
                  <path d="M3 11v-1a4 4 0 0 1 4-4h14" />
                  <path d="m7 22-4-4 4-4" />
                  <path d="M21 13v1a4 4 0 0 1-4 4H3" />
                </svg>
              )}
              {feature.icon === "zap" && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" />
                </svg>
              )}
            </span>
            <h3 class="text-foreground mb-2 font-sans text-lg font-extrabold">{feature.title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">{feature.body}</p>
          </Panel>
        ))
      }
    </div>

    <AppFooter />
  </div>
</div>
