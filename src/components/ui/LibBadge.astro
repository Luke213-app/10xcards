---
interface Props {
  label: string;
  version?: string;
}

const { label, version } = Astro.props;
---

<span
  class="border-foreground bg-card text-foreground inline-flex items-center gap-2 border-2 px-3 py-1.5 text-[11px] tracking-[0.1em] uppercase"
>
  {label}
  {
    version && (
      <span class="border-foreground bg-accent text-accent-foreground border-2 px-2 py-0.5 text-[10px]">{version}</span>
    )
  }
</span>
