---
import { cn } from "@/lib/utils";

// A non-hydrated call-to-action link usable from .astro pages, styled in
// the zen look (filled accent primary / ink-bordered secondary, both with
// the hard-shadow press). For interactive buttons inside React islands, use
// ui/button.tsx.
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  class?: string;
}

const { href, variant = "primary", class: className } = Astro.props;

const base =
  "zen-shadow zen-press inline-flex items-center justify-center gap-2 px-4 py-2 text-[11px] font-medium uppercase tracking-[0.08em] transition-colors";
const variants = {
  primary: "bg-primary text-primary-foreground hover:bg-[var(--accent-press)]",
  secondary: "bg-card text-foreground",
};
---

<a href={href} class:list={cn(base, variants[variant], className)}>
  <slot />
</a>
