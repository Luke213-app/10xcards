---
// The single authenticated top bar, replacing the four divergent per-page
// header rows. Server-rendered (no hydration). Sign-out lives behind the
// account avatar on the right (hover / keyboard-focus reveals the menu).
const { pathname } = Astro.url;
const { user } = Astro.locals;

const navLinks = [
  { label: "Dashboard", href: "/dashboard" },
  { label: "Learn", href: "/review" },
  { label: "Cards", href: "/cards" },
];

const isActive = (href: string) => pathname === href || pathname.startsWith(`${href}/`);
const initial = (user?.email?.[0] ?? "?").toUpperCase();
---

<header class="mx-auto mb-8 flex w-full max-w-5xl items-center justify-between gap-4">
  <a href="/" class="text-foreground flex items-center gap-2 transition-opacity hover:opacity-80">
    <span class="zen-shadow bg-primary text-primary-foreground flex size-8 items-center justify-center">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 2a3 3 0 0 0-3 3v14a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path>
        <path d="M9 8h6"></path>
      </svg>
    </span>
    <span class="font-sans text-base font-extrabold tracking-[-0.02em]">Recall</span>
  </a>

  <div class="flex items-center gap-2 sm:gap-3">
    <nav class="flex items-center gap-1 text-[11px] tracking-[0.1em] uppercase sm:gap-2" aria-label="Primary">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "border-2 px-3 py-1.5 transition-colors",
              isActive(link.href)
                ? "border-foreground bg-accent text-accent-foreground"
                : "text-muted-foreground hover:text-foreground border-transparent",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Account: avatar reveals a sign-out menu on hover / keyboard focus -->
    <div class="group relative">
      <button
        type="button"
        aria-label="Account menu"
        class="zen-shadow bg-primary text-primary-foreground focus-visible:ring-ring flex size-9 items-center justify-center text-sm font-semibold outline-none focus-visible:ring-2"
      >
        {initial}
      </button>
      <div
        class="zen-shadow bg-popover invisible absolute top-full right-0 z-30 mt-2 min-w-[11rem] p-1 opacity-0 transition-all group-focus-within:visible group-focus-within:opacity-100 group-hover:visible group-hover:opacity-100"
      >
        {user?.email && <p class="text-muted-foreground truncate px-3 py-1.5 text-xs">{user.email}</p>}
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="text-foreground hover:bg-accent hover:text-accent-foreground w-full px-3 py-1.5 text-left text-sm tracking-[0.08em] uppercase transition-colors"
          >
            Sign out
          </button>
        </form>
      </div>
    </div>
  </div>
</header>
